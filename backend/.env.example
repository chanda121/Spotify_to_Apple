# Copy to backend/.env and fill in values before running the backend.

# Random secret for express-session (e.g. openssl rand -base64 32)
SESSION_SECRET=

# Redis URL — matches docker-compose.yml when running locally
REDIS_URL=redis://127.0.0.1:6379

# Spotify Developer Dashboard → your app → Settings
SPOTIFY_CLIENT_ID=
# Must match a Redirect URI registered in the Spotify Dashboard exactly
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/auth/callback

# Where Spotify sends the user after login (Vite dev server in local dev)
FRONTEND_URL=http://127.0.0.1:5173

# Apple Developer → Keys → MusicKit key
APPLE_KID=
# Apple Developer → Membership → Team ID
APPLE_TEAM_ID=
# Contents of your .p8 private key. Use \n for line breaks on a single line.
APPLE_PRIVATE_KEY=

# Optional — defaults shown
PORT=3000
